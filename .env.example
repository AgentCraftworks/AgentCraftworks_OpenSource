# AgentCraftworks Community Edition — Docker Configuration
# Copy this file to .env and customize as needed

# ─── Database Configuration ─────────────────────────────────────────────────
# WARNING: Change these defaults before using in production!
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentcraftworks

# ─── TypeScript API Configuration ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agentcraftworks
REDIS_URL=redis://redis:6379

# ─── GitHub App Configuration ───────────────────────────────────────────────
# Uncomment and configure with your GitHub App credentials
# GH_CE_APP_ID=your_app_id             # Community Edition GitHub App numeric ID
# GH_CE_APP_PRIVATE_KEY=your_pem_key   # Full PEM contents of the CE GitHub App private key
# GH_CE_WEBHOOK_SECRET=your_secret     # Webhook HMAC secret for the CE GitHub App
